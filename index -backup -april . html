    .hero{height:100vh;position:relative;display:flex;align-items:flex-end;overflow:hidden}
    .hero-video{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center}
    .hero-ov{position:absolute;inset:0;background:linear-gradient(to bottom,rgba(5,4,2,.22) 0%,rgba(5,4,2,.52) 55%,rgba(5,4,2,1) 100%),linear-gradient(${isAr?"285deg":"105deg"},rgba(5,4,2,.58) 0%,transparent 60%)}
    .hero-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(184,149,90,.032) 1px,transparent 1px),linear-gradient(90deg,rgba(184,149,90,.032) 1px,transparent 1px);background-size:80px 80px}
    .hero-content{position:relative;z-index:10;padding:0 72px 96px;max-width:920px;${isAr?"margin-right:0;margin-left:auto;":""}}
    .hero-ey{font-size:10px;letter-spacing:.32em;text-transform:uppercase;color:var(--g);margin-bottom:26px;display:flex;align-items:center;gap:13px;opacity:0;animation:fadeUp 1s ease .3s forwards;font-family:${sans}}
    .hero-ey::${isAr?"after":"before"}{content:'';display:block;width:34px;height:1px;background:var(--g);flex-shrink:0}
    .hero-h1{font-family:${serif};font-size:clamp(46px,6.5vw,90px);font-weight:300;line-height:1.07;color:#f0e8dc;opacity:0;animation:fadeUp 1s ease .5s forwards}
    .hero-h1 em{font-style:${isAr?"normal":"italic"};color:var(--gl)}
    .hero-sub{font-size:${isAr?"15px":"13px"};letter-spacing:.05em;color:#9a9088;margin-top:22px;line-height:1.95;max-width:530px;opacity:0;animation:fadeUp 1s ease .7s forwards;font-weight:300}
    .hero-cta{margin-top:42px;display:flex;gap:16px;align-items:center;opacity:0;animation:fadeUp 1s ease .9s forwards;flex-wrap:wrap}
    .btn-p{background:var(--g);color:#0a0804;padding:14px 32px;font-family:${sans};font-size:${isAr?"13px":"10px"};letter-spacing:${isAr?".03em":".26em"};text-transform:${isAr?"none":"uppercase"};font-weight:500;border:none;cursor:pointer;transition:filter .3s,transform .2s}
    .btn-p:hover{filter:brightness(1.13);transform:translateY(-1px)}
    .btn-g{background:transparent;color:#c5bdb5;padding:14px 32px;font-family:${sans};font-size:${isAr?"13px":"10px"};letter-spacing:${isAr?".03em":".26em"};text-transform:${isAr?"none":"uppercase"};font-weight:400;border:1px solid rgba(197,189,181,.28);cursor:pointer;transition:border-color .3s,color .3s}
    .btn-g:hover{border-color:var(--g);color:var(--g)}
    .hero-scroll{position:absolute;${isAr?"left:48px":"right:48px"};bottom:88px;display:flex;flex-direction:column;align-items:center;gap:11px;color:#4a4540;font-size:9px;letter-spacing:.28em;text-transform:uppercase;writing-mode:vertical-rl;opacity:0;animation:fadeIn 1s ease 1.5s forwards}
    .scroll-ln{width:1px;height:52px;background:linear-gradient(to bottom,var(--g),transparent);animation:scAnim 2s ease-in-out infinite}

    /* STATS */
    .stats{display:grid;grid-template-columns:repeat(4,1fr);border-top:1px solid rgba(184,149,90,.14);border-bottom:1px solid rgba(184,149,90,.14)}
    .stat{padding:50px 42px;border-${isAr?"left":"right"}:1px solid rgba(184,149,90,.09);position:relative;overflow:hidden;transition:background .4s}
    .stat:last-child{border:none}
    .stat:hover{background:rgba(184,149,90,.03)}
    .stat-n{font-family:${serif};font-size:48px;font-weight:300;color:var(--g);line-height:1;display:block}
    .stat-l{font-size:${isAr?"12px":"10px"};letter-spacing:.14em;text-transform:uppercase;color:#4a4440;margin-top:10px;font-weight:300}
    .stat::before{content:'';position:absolute;top:0;${isAr?"right":"left"}:0;width:2px;height:0;background:var(--g);transition:height .4s}
    .stat:hover::before{height:100%}

    /* EYEBROW / TITLE */
    .eyebrow{font-size:${isAr?"12px":"10px"};letter-spacing:.32em;text-transform:${isAr?"none":"uppercase"};color:var(--g);margin-bottom:16px;display:flex;align-items:center;gap:13px;font-weight:400}
    .eyebrow::${isAr?"after":"before"}{content:'';display:block;width:26px;height:1px;background:var(--g);flex-shrink:0}
    .sec-title{font-family:${serif};font-size:clamp(34px,4.5vw,62px);font-weight:300;line-height:1.12;color:#f0e8dc}

    /* SERVICES */
    .svc-sec{padding:116px 72px;max-width:1400px;margin:0 auto}
    .svc-hd{display:grid;grid-template-columns:1fr 1fr;gap:72px;margin-bottom:68px;align-items:end}
    .svc-desc{color:#888078;font-size:${isAr?"14px":"13px"};line-height:2;align-self:end}
    .svc-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(184,149,90,.08)}
    .svc-card{background:var(--bg);padding:44px 34px;position:relative;overflow:hidden;transition:background .4s;cursor:default}
    .svc-card::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(184,149,90,.055) 0%,transparent 60%);opacity:0;transition:opacity .4s}
    .svc-card:hover{background:#0d0b08}
    .svc-card:hover::before{opacity:1}
    .svc-num{font-family:${serif};font-size:11px;color:var(--gd);letter-spacing:.18em;margin-bottom:26px;display:block}
    .svc-name{font-family:${serif};font-size:${isAr?"20px":"24px"};font-weight:${isAr?"400":"300"};color:#e8e0d4;line-height:1.3;margin-bottom:14px}
    .svc-detail{font-size:${isAr?"13px":"11px"};color:#4a4440;line-height:2}
    .svc-arr{position:absolute;bottom:34px;${isAr?"left":"right"}:34px;width:28px;height:28px;border:1px solid rgba(184,149,90,.18);display:flex;align-items:center;justify-content:center;font-size:12px;color:var(--g);opacity:0;transform:translateX(${isAr?"7px":"-7px"});transition:opacity .3s,transform .3s}
    .svc-card:hover .svc-arr{opacity:1;transform:translateX(0)}

    /* PROJECTS */
    .proj-sec{padding:116px 72px;max-width:1400px;margin:0 auto}
    .proj-hd{margin-bottom:52px}
    .proj-grid{display:grid;grid-template-columns:1.4fr 1fr;grid-template-rows:auto auto;gap:16px}
    .proj-card{position:relative;overflow:hidden;cursor:pointer}
    .proj-card.tall{grid-row:span 2}
    .proj-inner{height:100%;min-height:290px;background:#111009;position:relative;overflow:hidden}
    .proj-card.tall .proj-inner{min-height:640px}
    .proj-ov{position:absolute;inset:0;background:linear-gradient(to top,rgba(5,4,2,.94) 0%,rgba(5,4,2,.22) 55%,transparent 100%)}
    .proj-ph{position:absolute;inset:0;background:linear-gradient(135deg,#0e0c08 0%,#1a1609 50%,#0b0909 100%);transition:transform .7s}
    .proj-card:hover .proj-ph{transform:scale(1.04)}
    .proj-pat{position:absolute;inset:0;opacity:.09;background-image:repeating-linear-gradient(45deg,rgba(184,149,90,.4) 0,rgba(184,149,90,.4) 1px,transparent 1px,transparent 24px)}
    .proj-info{position:absolute;bottom:0;left:0;right:0;padding:34px}
    .proj-cat{font-size:9px;letter-spacing:.28em;text-transform:uppercase;color:var(--g);margin-bottom:7px}
    .proj-name{font-family:${serif};font-size:27px;font-weight:300;color:#f0e8dc;line-height:1.2}
    .proj-card.tall .proj-name{font-size:37px}
    .proj-loc{font-size:10px;color:#4a4540;letter-spacing:.1em;margin-top:9px;opacity:0;transform:translateY(7px);transition:opacity .3s,transform .3s}
    .proj-card:hover .proj-loc{opacity:1;transform:translateY(0)}

    /* PHILOSOPHY */
    .phil-sec{padding:126px 72px;max-width:1400px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:104px;align-items:center;border-top:1px solid rgba(184,149,90,.09)}
    .phil-q{font-family:${serif};font-size:clamp(26px,3.5vw,48px);font-weight:300;line-height:1.42;color:#f0e8dc;font-style:${isAr?"normal":"italic"}}
    .phil-q span{color:var(--gl)}
    .phil-body{color:var(--mut);font-size:${isAr?"14px":"13px"};line-height:2.2;margin-bottom:14px}
    .phil-div{width:48px;height:1px;background:var(--g);margin:26px 0}
    .phil-sig{font-family:${serif};font-size:${isAr?"16px":"17px"};color:var(--g);font-style:${isAr?"normal":"italic"}}

    /* ABOUT */
    .about-sec{padding:116px 72px;max-width:1400px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:72px;align-items:center;border-top:1px solid rgba(184,149,90,.09)}
    .about-vis{position:relative;height:520px}
    .about-main{position:absolute;inset:0;background:linear-gradient(135deg,#0e0c08 0%,#1a1408 100%);border:1px solid rgba(184,149,90,.11)}
    .about-pat{position:absolute;inset:0;opacity:.06;background-image:repeating-linear-gradient(-45deg,rgba(184,149,90,.5) 0,rgba(184,149,90,.5) 1px,transparent 1px,transparent 30px)}
    .about-acc{position:absolute;width:164px;height:164px;bottom:-16px;${isAr?"left:-16px":"right:-16px"};background:rgba(184,149,90,.05);border:1px solid rgba(184,149,90,.16);z-index:2;display:flex;align-items:center;justify-content:center}
    .about-acc-txt{font-family:${serif};font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--g);text-align:center;line-height:2}
    .about-body{color:var(--mut);font-size:${isAr?"14px":"13px"};line-height:2.2;margin-bottom:16px}
    .about-feats{margin-top:32px;display:grid;grid-template-columns:1fr 1fr;gap:14px}
    .about-feat{padding:16px;border:1px solid rgba(184,149,90,.1);position:relative;transition:border-color .3s,background .3s}
    .about-feat:hover{border-color:rgba(184,149,90,.22);background:rgba(184,149,90,.03)}
    .about-feat::before{content:'';position:absolute;top:0;left:0;width:100%;height:1px;background:linear-gradient(${isAr?"to left":"to right"},var(--g),transparent)}
    .about-feat-t{font-size:${isAr?"12px":"10px"};letter-spacing:.14em;text-transform:uppercase;color:var(--g);margin-bottom:5px;font-weight:500}
    .about-feat-d{font-size:${isAr?"12px":"11px"};color:#3a3430;line-height:1.8}

    /* CONTACT */
    .contact-sec{padding:144px 72px;text-align:center;position:relative;overflow:hidden;border-top:1px solid rgba(184,149,90,.09)}
    .contact-bg{position:absolute;inset:0;background:radial-gradient(ellipse at center,rgba(184,149,90,.042) 0%,transparent 66%)}
    .contact-ttl{font-family:${serif};font-size:clamp(42px,5.5vw,82px);font-weight:300;color:#f0e8dc;line-height:1.1;margin-bottom:18px;position:relative}
    .contact-ttl em{font-style:${isAr?"normal":"italic"};color:var(--gl)}
    .contact-sub{color:#4a4440;font-size:${isAr?"13px":"11px"};letter-spacing:.18em;text-transform:uppercase;margin-bottom:48px;position:relative}
    .contact-row{display:flex;justify-content:center;gap:16px;position:relative;flex-wrap:wrap}
    .offices{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:rgba(184,149,90,.07);max-width:1000px;margin:60px auto 0;position:relative}
    .off-card{background:var(--bg);padding:32px 24px;transition:background .3s;text-align:${isAr?"right":"left"}}
    .off-card:hover{background:rgba(184,149,90,.035)}
    .off-reg{font-size:${isAr?"13px":"10px"};letter-spacing:.22em;text-transform:uppercase;color:var(--gd);margin-bottom:14px;font-weight:500;border-bottom:1px solid rgba(184,149,90,.1);padding-bottom:11px}
    .off-ph{display:block;font-family:'Montserrat',sans-serif;font-size:13px;color:#7a7268;text-decoration:none;letter-spacing:.05em;padding:4px 0;transition:color .25s,text-shadow .25s;font-weight:300;direction:ltr;${isAr?"text-align:right":""}}
    .off-ph:hover{color:var(--gl);text-shadow:0 0 16px rgba(212,174,116,.48),0 0 32px rgba(212,174,116,.18)}

    /* FOOTER */
    footer{padding:44px 72px 32px;border-top:1px solid rgba(184,149,90,.07)}
    .ft-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:28px;flex-wrap:wrap;gap:20px}
    .ft-name-en{font-family:'Cormorant Garamond',serif;font-size:19px;color:var(--gd);letter-spacing:.22em;font-weight:300;display:block;margin-bottom:5px}
    .ft-name-ar{font-family:'Tajawal',sans-serif;font-size:17px;color:var(--gd);letter-spacing:.04em;font-weight:300;opacity:.7;display:block;direction:rtl}
    .ft-full{font-size:10px;color:#2e2b27;letter-spacing:.09em;margin-top:9px;line-height:2}
    .ft-bot{border-top:1px solid rgba(184,149,90,.05);padding-top:20px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px}
    .ft-copy{font-size:10px;color:#252220;letter-spacing:.09em}

    /* REVEAL */
    .reveal{opacity:0;transform:translateY(26px);transition:opacity .85s ease,transform .85s ease}
    .reveal.visible{opacity:1;transform:translateY(0)}
    .reveal-delay-1{transition-delay:.12s}
    .reveal-delay-2{transition-delay:.24s}
    .reveal-delay-3{transition-delay:.36s}
    .reveal-delay-4{transition-delay:.48s}
    .reveal-delay-5{transition-delay:.6s}
    .reveal-delay-6{transition-delay:.72s}

    /* KEYFRAMES */
    @keyframes fadeUp{from{opacity:0;transform:translateY(26px)}to{opacity:1;transform:translateY(0)}}
    @keyframes fadeIn{from{opacity:0}to{opacity:1}}
    @keyframes scAnim{0%,100%{transform:scaleY(1);opacity:1}50%{transform:scaleY(.4);opacity:.3}}

    /* RESPONSIVE 1100 */
    @media(max-width:1100px){
      .mega-grid{grid-template-columns:repeat(3,1fr)}
      .svc-grid{grid-template-columns:repeat(2,1fr)}
      .proj-grid{grid-template-columns:1fr}
      .proj-card.tall{grid-row:span 1}
      .proj-card.tall .proj-inner{min-height:380px}
      .offices{grid-template-columns:repeat(2,1fr)}
    }

    /* RESPONSIVE 768 */
    @media(max-width:768px){
      nav{padding:16px 22px}
      nav.scrolled{padding:11px 22px}
      .nav-links,.lang-btn{display:none}
      .hamburger{display:flex}
      .mega-dd{padding:76px 22px 38px}
      .mega-grid{grid-template-columns:repeat(2,1fr);gap:22px}
      .social-bar{${isAr?"left:unset;":"right:unset;"}top:unset;bottom:0;left:0;right:0;transform:none;flex-direction:row;justify-content:center;background:rgba(5,4,2,.9);border-top:1px solid rgba(184,149,90,.11);padding:5px 0}
      .soc-icon{border:none;background:rgba(184,149,90,.07);width:50px;height:42px}
      .soc-icon:hover{transform:translateY(-2px)}
      .hero-content{padding:0 22px 110px}
      .hero-scroll{display:none}
      .stats{grid-template-columns:repeat(2,1fr)}
      .stat{padding:34px 22px}
      .stat:nth-child(2){border-${isAr?"left":"right"}:none}
      .stat:nth-child(3){border-top:1px solid rgba(184,149,90,.09)}
      .svc-sec,.proj-sec,.phil-sec,.about-sec,.contact-sec{padding:76px 22px}
      .svc-hd{grid-template-columns:1fr;gap:20px}
      .svc-grid{grid-template-columns:1fr}
      .proj-grid{grid-template-columns:1fr;gap:10px}
      .phil-sec{grid-template-columns:1fr;gap:44px}
      .about-sec{grid-template-columns:1fr;gap:44px}
      .about-vis{height:280px}
      .about-feats{grid-template-columns:1fr}
      .offices{grid-template-columns:1fr 1fr}
      .off-card{padding:22px 16px}
      footer{padding:36px 22px 76px}
      .ft-top{flex-direction:column}
      .ft-bot{flex-direction:column;align-items:flex-start;gap:7px}
    }

    /* RESPONSIVE 480 */
    @media(max-width:480px){
      .hero-h1{font-size:clamp(34px,10vw,54px)}
      .hero-cta{flex-direction:column;align-items:flex-start;gap:10px}
      .btn-p,.btn-g{width:100%;text-align:center}
      .stat-n{font-size:34px}
      .sec-title{font-size:clamp(28px,8vw,44px)}
      .contact-ttl{font-size:clamp(30px,9vw,50px)}
      .offices{grid-template-columns:1fr}
      .mega-grid{grid-template-columns:1fr}
      .contact-row{flex-direction:column;align-items:center}
    }
  `;

  return (
    <div dir={t.dir}>
      <style>{css}</style>

      {/* SOCIAL BAR */}
      <aside className="social-bar">
        <a className="soc-icon" href="https://instagram.com" target="_blank" rel="noreferrer" title="Instagram"><IconIG /></a>
        <a className="soc-icon" href="https://wa.me/97431671083" target="_blank" rel="noreferrer" title="WhatsApp"><IconWA /></a>
        <a className="soc-icon" href="mailto:hello@naqigulf.com" title="Email"><IconEmail /></a>
        <a className="soc-icon" href="https://tiktok.com" target="_blank" rel="noreferrer" title="TikTok"><IconTT /></a>
        <a className="soc-icon" href="tel:+97431671083" title="Call +974 3167 1083"><IconPhone /></a>
      </aside>

      {/* NAV */}
      <nav className={scrolled ? "scrolled" : ""}>
        <div className="nav-brand">
          <div className="nav-logo">{t.logo}</div>
          <span className="nav-sub">{t.logoSub}</span>
        </div>
        <div className="nav-right">
          <ul className="nav-links">
            {t.navLinks.map((label, i) => {
              const keys = ["services","materials","projects","about","contact"];
              return i === 1 ? (
                <li key={i}>
                  <button className="nav-item-btn" onClick={() => setMegaOpen(o => !o)}>{label}</button>
                </li>
              ) : (
                <li key={i}>
                  <a href={`#${keys[i]}`}>{label}</a>
                </li>
              );
            })}
          </ul>
          <button className="lang-btn" onClick={toggleLang}>{t.langToggle}</button>
          <button className={`hamburger${mobileOpen ? " open" : ""}`} onClick={() => setMobileOpen(o => !o)} aria-label="Menu">
            <span /><span /><span />
          </button>
        </div>
      </nav>

      {/* MEGA DROPDOWN */}
      <div className={`mega-dd${megaOpen ? " open" : ""}`}>
        <button className="mega-close" onClick={() => setMegaOpen(false)}>✕</button>
        <div className="mega-grid">
          {mats.map((col, i) => (
            <div key={i}>
              <div className="mega-cat">{col.cat}</div>
              {col.items.map((item, j) => <span key={j} className="mega-item">{item}</span>)}
            </div>
          ))}
        </div>
      </div>

      {/* MOBILE MENU */}
      <div className={`mobile-menu${mobileOpen ? " open" : ""}`}>
        {t.navLinks.map((label, i) => {
          const keys = ["services","materials","projects","about","contact"];
          return i === 1 ? (
            <button key={i} className="mob-link" onClick={() => { setMobileOpen(false); setMegaOpen(true); }}>{label}</button>
          ) : (
            <a key={i} href={`#${keys[i]}`} onClick={() => setMobileOpen(false)}>{label}</a>
          );
        })}
        <button className="lang-btn" onClick={toggleLang} style={{marginTop:14}}>{t.langToggle}</button>
      </div>

      {/* HERO */}
      <section className="hero">
        <video className="hero-video" autoPlay muted loop playsInline
          src="/Users/muhanmod/Desktop/NAQIGUFL/images hero-bg.mp4" />
        <div className="hero-ov" />
        <div className="hero-grid" />
        <div className="hero-content">
          <div className="hero-ey">{t.heroEyebrow}</div>
          <h1 className="hero-h1">{t.heroH1[0]}<br />{t.heroH1[1]}<em>{t.heroH1[2]}</em></h1>
          <p className="hero-sub">{t.heroSub}</p>
          <div className="hero-cta">
            <button className="btn-p">{t.heroCta1}</button>
            <button className="btn-g">{t.heroCta2}</button>
          </div>
        </div>
        <div className="hero-scroll"><div className="scroll-ln" />{t.scrollLabel}</div>
      </section>

      {/* STATS */}
      <div className="stats">
        {t.statsData.map((s, i) => (
          <div key={i} className={`stat reveal reveal-delay-${i+1}`}>
            <span className="stat-n">{s.num}</span>
            <div className="stat-l">{s.label}</div>
          </div>
        ))}
      </div>

      {/* SERVICES */}
      <section id="services" className="svc-sec">
        <div className="svc-hd">
          <div>
            <div className="eyebrow reveal">{t.servicesEyebrow}</div>
            <h2 className="sec-title reveal reveal-delay-1">{t.servicesTitle[0]}<br />{t.servicesTitle[1]}</h2>
          </div>
          <p className="svc-desc reveal reveal-delay-2">{t.servicesDesc}</p>
        </div>
        <div className="svc-grid">
          {t.services.map((s, i) => (
            <div key={i} className={`svc-card reveal reveal-delay-${(i%3)+1}`}>
              <span className="svc-num">0{i+1}</span>
              <div className="svc-name">{s.name}</div>
              <p className="svc-detail">{s.detail}</p>
              <div className="svc-arr">{isAr ? "←" : "→"}</div>
            </div>
          ))}
        </div>
      </section>

      {/* PROJECTS */}
      <section id="projects" className="proj-sec">
        <div className="proj-hd">
          <div className="eyebrow reveal">{t.projectsEyebrow}</div>
          <h2 className="sec-title reveal reveal-delay-1">{t.projectsTitle}</h2>
        </div>
        <div className="proj-grid reveal">
          {t.projects.map((p, i) => (
            <div key={i} className={`proj-card${p.tall ? " tall" : ""}`}>
              <div className="proj-inner">
                <div className="proj-ph"><div className="proj-pat" /></div>
                <div className="proj-ov" />
                <div className="proj-info">
                  <div className="proj-cat">{p.category}</div>
                  <div className="proj-name">{p.name}</div>
                  <div className="proj-loc">{p.location}</div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>

      {/* PHILOSOPHY */}
      <section className="phil-sec">
        <div className="phil-q reveal">
          {t.philosophyQuote[0]}<br />{t.philosophyQuote[1]}<span>{t.philosophyQuote[2]}</span>{t.philosophyQuote[3]}<br />
          {t.philosophyQuote[4]}<br />{t.philosophyQuote[5]}
        </div>
        <div>
