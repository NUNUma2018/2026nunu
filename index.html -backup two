        <div className="hero-bg" />
        <div className="hero-grid" />
        <div className="hero-orb" />

        <div className="hero-content">
          <div className="hero-eyebrow">Qatar & Saudi Arabia</div>
          <h1 className="hero-h1">
            Where Architecture<br />
            Becomes <em>Identity</em>
          </h1>
          <p className="hero-sub">
            Luxury villa & Majlis design crafted with cultural precision,<br />
            architectural excellence, and uncompromising detail.
          </p>
          <div className="hero-cta">
            <button className="btn-primary">Free Consultation</button>
            <button className="btn-ghost">WhatsApp Us</button>
          </div>
        </div>

        <div className="hero-scroll">
          <div className="scroll-line" />
          Scroll
        </div>
      </section>

      {/* STATS */}
      <div className="stats">
        {[
          { num: "15+", label: "Years of Excellence" },
          { num: "300+", label: "Luxury Projects" },
          { num: "500M+", label: "QAR Project Value" },
