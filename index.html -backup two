/* ─── RESPONSIVE ─── */
@media (max-width: 1024px) {
  .dropdown-mega { width: 520px; }
  .dropdown-grid { grid-template-columns: repeat(2, 1fr); }
  .services-grid { grid-template-columns: repeat(2, 1fr); }
  .footer-grid { grid-template-columns: 1fr 1fr; gap: 32px; }
}

@media (max-width: 768px) {
  header { padding: 0 20px; height: 70px; }
  nav { display: none; }
  .hamburger { display: flex; }
  .lang-toggle { top: 14px; right: 64px; }
  body[dir="rtl"] .lang-toggle { right: auto; left: 64px; }

  .social-float {
    position: fixed;
    left: 0; right: 0;
    bottom: 0;
    top: auto;
    transform: none;
    flex-direction: row;
    justify-content: center;
    gap: 8px;
    padding: 10px 16px;
    background: rgba(10,22,40,0.95);
